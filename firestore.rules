rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // NOTE: Custom username/password auth – Firebase Auth is not used.
    // All reads/writes are allowed for now. Restrict in production.
    
    // Users collection – allow read for login, allow write for profile updates
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // Messages – allow all for real-time chat
    match /messages/{messageId} {
      allow read, write: if true;
    }
    
    // Posts – News Feed
    match /posts/{postId} {
      allow read, write: if true;
    }
    
    // Attendance records
    match /attendance/{recordId} {
      allow read, write: if true;
    }
    
    // Score records
    match /scores/{scoreId} {
      allow read, write: if true;
    }
    
    // Homework assignments
    match /homework/{hwId} {
      allow read, write: if true;
    }
    
    // Bookings
    match /bookings/{bookingId} {
      allow read, write: if true;
    }
  }
}
